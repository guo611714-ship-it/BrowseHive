"""[EDGE] LLM 调用辅助函数"""

import logging
from typing import Optional

logger = logging.getLogger(__name__)


async def call_llm(model_client, prompt: str, system: str = "") -> Optional[str]:
    """统一的 LLM 调用封装

    Args:
        model_client: LLM 客户端实例（需有 .chat() 方法）
        prompt: 用户提示
        system: 系统提示

    Returns:
        LLM 回复文本，失败返回 None
    """
    if not model_client:
        return None
    try:
        response = await model_client.chat(
            messages=[{"role": "user", "content": prompt}],
            system=system,
        )
        return response.get("content", "")
    except Exception as e:
        logger.error("LLM 调用失败: %s", e)
        return None
